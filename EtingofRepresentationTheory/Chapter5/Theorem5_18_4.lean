import Mathlib

/-!
# Theorem 5.18.4: Schur-Weyl Duality

The fundamental Schur-Weyl duality theorem for V^⊗n:

(i) Let A = Im(k[S_n] → End(V^⊗n)) and B = Im(U(gl(V)) → End(V^⊗n)).
    Then A = End_B(V^⊗n) and B = End_A(V^⊗n).

(ii) Both A and B are semisimple, and V^⊗n is a semisimple gl(V)-module.

(iii) As an (A ⊗ B)-module:
      V^⊗n ≅ ⊕ Vpart ⊗ Lpart
      where Vpart ranges over Specht modules of S_n and Lpart are the
      corresponding irreducible polynomial representations of GL(V).

## Mathlib correspondence

Schur-Weyl duality is a deep theorem connecting representation theory of S_n
and GL(V). We use `PiTensorProduct` for V^⊗n, `MonoidAlgebra` for k[S_n],
and `Subalgebra.centralizer` for the commutant.
-/

open scoped TensorProduct

namespace Etingof

variable (k : Type*) [Field k]
  (V : Type*) [AddCommGroup V] [Module k V] [Module.Finite k V]
  (n : ℕ)

/-- The n-th tensor power V^⊗n as a type. -/
abbrev TensorPower := ⨂[k] (_ : Fin n), V

/-- The symmetric group action on V^⊗n by permuting tensor factors.
Given σ ∈ S_n, this sends v₁ ⊗ ... ⊗ vₙ to v_{σ⁻¹(1)} ⊗ ... ⊗ v_{σ⁻¹(n)}.
This is a linear equivalence, hence an element of End_k(V^⊗n). -/
noncomputable def symGroupAction (σ : Equiv.Perm (Fin n)) :
    TensorPower k V n ≃ₗ[k] TensorPower k V n :=
  PiTensorProduct.reindex k (fun _ => V) σ

/-- The image of k[S_n] in End(V^⊗n), defined as the subalgebra
generated by the symmetric group action on tensor factors.

This is the subalgebra of End_k(V^⊗n) generated by all permutation
operators σ : V^⊗n → V^⊗n for σ ∈ S_n. -/
noncomputable def symGroupImage :
    Subalgebra k (Module.End k (TensorPower k V n)) :=
  Algebra.adjoin k (Set.range fun (σ : Equiv.Perm (Fin n)) =>
    (symGroupAction k V n σ).toLinearMap)

/-- The diagonal action subalgebra: the image of the diagonal action of
End_k(V) on V^⊗n, where f ∈ End_k(V) acts as f ⊗ f ⊗ ... ⊗ f.
This is the subalgebra generated by the image of GL(V) (equivalently,
the image of the universal enveloping algebra U(gl(V))). -/
noncomputable def diagonalActionImage :
    Subalgebra k (Module.End k (TensorPower k V n)) :=
  Algebra.adjoin k (Set.range fun (f : Module.End k V) =>
    PiTensorProduct.map (fun _ => f))

/-- Schur-Weyl duality, part (i): The images of k[S_n] and End_k(V)
in End(V^⊗n) are mutual centralizers.

Specifically, symGroupImage = centralizer(diagonalActionImage) and
diagonalActionImage = centralizer(symGroupImage).
(Etingof Theorem 5.18.4, part i) -/
theorem Theorem5_18_4_centralizers
    (hN : n ≤ Module.finrank k V) :
    symGroupImage k V n = Subalgebra.centralizer k
      (diagonalActionImage k V n :
        Set (Module.End k (TensorPower k V n)))
    ∧ diagonalActionImage k V n = Subalgebra.centralizer k
      (symGroupImage k V n :
        Set (Module.End k (TensorPower k V n))) := by
  sorry

/-- Schur-Weyl duality, part (ii): The symmetric group and diagonal
action subalgebras of End(V^⊗n) are both semisimple.
(Etingof Theorem 5.18.4, part ii) -/
theorem Theorem5_18_4_semisimple
    (hN : n ≤ Module.finrank k V) :
    IsSemisimpleRing (symGroupImage k V n)
    ∧ IsSemisimpleRing (diagonalActionImage k V n) := by
  sorry

/-- Schur-Weyl duality, part (iii): Decomposition of V^⊗n.

V^⊗n decomposes as a direct sum of tensor products of simple modules:
  V^⊗n ≅ ⊕_i S_i ⊗ L_i
where {S_i} are the distinct simple k[S_n]-modules (Specht modules)
appearing in V^⊗n and {L_i} are the corresponding irreducible
polynomial GL(V)-representations.
(Etingof Theorem 5.18.4, part iii) -/
theorem Theorem5_18_4_decomposition
    (hN : n ≤ Module.finrank k V) :
    ∃ (ι : Type) (_ : Fintype ι) (_ : DecidableEq ι)
      (S L : ι → Type)
      (_ : ∀ i, AddCommGroup (S i)) (_ : ∀ i, Module k (S i))
      (_ : ∀ i, AddCommGroup (L i)) (_ : ∀ i, Module k (L i)),
      Nonempty (TensorPower k V n ≃ₗ[k]
        DirectSum ι (fun i => S i ⊗[k] L i)) := by
  sorry

end Etingof
